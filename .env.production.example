# ===========================================
# Batuara.net - Production Environment Variables
# ===========================================
# Copy this file to .env.production and fill in real values.
# NEVER commit .env.production to git!

# --- Database ---
# Generate a strong password: openssl rand -base64 32
DB_PASSWORD=CHANGE_ME_SET_SECURE_PASSWORD
DB_NAME=batuara_db

# --- JWT Secret ---
# Minimum 32 characters. Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_64

# --- Application ---
ENVIRONMENT=Production
ASPNETCORE_ENVIRONMENT=Production

# --- Docker / Compose ---
COMPOSE_PROJECT_NAME=batuara-net
PROJECT_NAME=batuara
DOCKER_NETWORK=www_projetos-net
VOLUME_PREFIX=batuara
IMAGE_TAG=latest

# --- Ports ---
PUBLIC_WEBSITE_PORT=3000
ADMIN_DASHBOARD_PORT=3001
API_PORT=3003

# --- Frontend API URL ---
# Adjust to match your production domain/IP
REACT_APP_API_URL=/batuara-api/api

# --- HTTPS (optional, for Let's Encrypt) ---
# DOMAIN=batuara.net
# CERTBOT_EMAIL=admin@batuara.net
