# Auto detect text files and perform LF normalization in repo,
# native line endings on checkout (CRLF on Windows, LF on Linux/Mac)
* text=auto

# Source code - normalize to LF in repo, native on checkout
*.cs text
*.tsx text
*.ts text
*.js text
*.jsx text
*.css text
*.scss text
*.html text
*.json text
*.xml text
*.yml text
*.yaml text
*.md text
*.txt text
*.sql text
*.py text
*.toml text
*.conf text
*.http text
*.env text
*.example text

# .NET project files
*.csproj text
*.props text
*.targets text

# Solution files - Visual Studio requires CRLF
*.sln text eol=crlf

# Shell scripts - must be LF for Unix execution
*.sh text eol=lf
*.bash text eol=lf

# PowerShell - CRLF for Windows compatibility
*.ps1 text eol=crlf
*.psm1 text eol=crlf

# Docker - must be LF for Linux container execution
Dockerfile text eol=lf
*.dockerfile text eol=lf
docker-compose*.yml text eol=lf

# Git config
.gitattributes text
.gitignore text
.editorconfig text

# Binary files - no line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.pdf binary
*.mp4 binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
