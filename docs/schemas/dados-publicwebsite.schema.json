{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://batuara.net/schemas/dados-publicwebsite.schema.json",
  "type": "object",
  "required": [
    "meta",
    "orixas",
    "guiasEntidades",
    "linhasUmbanda",
    "oracoes"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "required": [
        "schemaVersion",
        "datasetVersion",
        "source",
        "sourceDocuments",
        "createdAt",
        "updatedAt",
        "totalOrixas",
        "totalGuias",
        "totalLinhas",
        "totalOracoes"
      ],
      "properties": {
        "schemaVersion": { "type": "string", "minLength": 1 },
        "datasetVersion": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "sourceDocuments": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "totalOrixas": { "type": "integer", "minimum": 1 },
        "totalGuias": { "type": "integer", "minimum": 1 },
        "totalLinhas": { "type": "integer", "minimum": 1 },
        "totalOracoes": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": true
    },
    "orixas": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/orixa" }
    },
    "guiasEntidades": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/guia" }
    },
    "linhasUmbanda": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/linha" }
    },
    "forcasNatureza": {
      "type": "object"
    },
    "oracoes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/oracao" }
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "required": [
        "status",
        "primarySource",
        "updatedAt"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "validated",
            "derived",
            "legacy",
            "mixed"
          ]
        },
        "primarySource": { "type": "string", "minLength": 1 },
        "pages": {
          "type": "array",
          "items": { "type": "integer", "minimum": 1 }
        },
        "notes": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": true
    },
    "orixa": {
      "type": "object",
      "required": [
        "id",
        "slug",
        "name",
        "description",
        "origin",
        "batuaraTeaching",
        "displayOrder",
        "characteristics",
        "colors",
        "elements",
        "element",
        "habitat",
        "atuacao",
        "saudacao",
        "simbolo",
        "cor",
        "diaSemana",
        "fruta",
        "comida",
        "bebida",
        "dataComemoracao",
        "isActive",
        "source",
        "createdAt",
        "updatedAt"
      ],
      "properties": {
        "id": { "type": "integer", "minimum": 1 },
        "slug": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "origin": { "type": "string", "minLength": 1 },
        "batuaraTeaching": { "type": "string", "minLength": 1 },
        "displayOrder": { "type": "integer", "minimum": 1 },
        "characteristics": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "colors": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "elements": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "element": { "type": "string", "minLength": 1 },
        "habitat": { "type": "string", "minLength": 1 },
        "atuacao": { "type": "string", "minLength": 1 },
        "saudacao": { "type": "string", "minLength": 1 },
        "simbolo": { "type": "string", "minLength": 1 },
        "cor": { "type": "string", "minLength": 1 },
        "diaSemana": { "type": "string", "minLength": 1 },
        "fruta": { "type": "string", "minLength": 1 },
        "comida": { "type": "string", "minLength": 1 },
        "bebida": { "type": "string", "minLength": 1 },
        "dataComemoracao": { "type": "string", "minLength": 1 },
        "isActive": { "type": "boolean" },
        "source": { "$ref": "#/$defs/source" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": true
    },
    "guia": {
      "type": "object",
      "required": [
        "id",
        "slug",
        "name",
        "comemoracao",
        "saudacao",
        "habitat",
        "cor",
        "diaSemana",
        "bebida",
        "fruta",
        "comida",
        "description",
        "caracteristicas",
        "isActive",
        "source",
        "createdAt",
        "updatedAt"
      ],
      "properties": {
        "id": { "type": "integer", "minimum": 1 },
        "slug": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "comemoracao": { "type": "string", "minLength": 1 },
        "saudacao": { "type": "string", "minLength": 1 },
        "habitat": { "type": "string", "minLength": 1 },
        "cor": { "type": "string", "minLength": 1 },
        "diaSemana": { "type": "string", "minLength": 1 },
        "bebida": { "type": "string", "minLength": 1 },
        "fruta": { "type": "string", "minLength": 1 },
        "comida": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "caracteristicas": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "isActive": { "type": "boolean" },
        "source": { "$ref": "#/$defs/source" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": true
    },
    "linha": {
      "type": "object",
      "required": [
        "id",
        "slug",
        "name",
        "regidaPor",
        "entidades",
        "atuacao",
        "cor",
        "description",
        "displayOrder",
        "workingDays",
        "isActive",
        "source",
        "createdAt",
        "updatedAt"
      ],
      "properties": {
        "id": { "type": "integer", "minimum": 1 },
        "slug": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "regidaPor": { "type": "string", "minLength": 1 },
        "entidades": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "relatedGuides": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "atuacao": { "type": "string", "minLength": 1 },
        "cor": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "displayOrder": { "type": "integer", "minimum": 1 },
        "workingDays": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "isActive": { "type": "boolean" },
        "source": { "$ref": "#/$defs/source" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": true
    },
    "oracao": {
      "type": "object",
      "required": [
        "id",
        "slug",
        "title",
        "content",
        "type",
        "category",
        "source",
        "displayOrder",
        "isFeatured",
        "isActive",
        "createdAt",
        "updatedAt"
      ],
      "properties": {
        "id": { "type": "integer", "minimum": 1 },
        "slug": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "content": { "type": "string", "minLength": 1 },
        "type": { "type": "integer", "minimum": 1, "maximum": 5 },
        "category": { "type": "integer", "minimum": 1, "maximum": 4 },
        "source": {
          "oneOf": [
            { "type": "string", "minLength": 1 },
            { "$ref": "#/$defs/source" }
          ]
        },
        "displayOrder": { "type": "integer", "minimum": 1 },
        "isFeatured": { "type": "boolean" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
