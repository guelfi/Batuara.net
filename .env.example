# Configuração de Portas
PUBLIC_WEBSITE_PORT=3000
ADMIN_DASHBOARD_PORT=3001
API_PORT=3003

# Configuração da API
REACT_APP_API_URL=http://localhost:3003

# Database
# IMPORTANTE: Defina uma senha forte e única para produção
DB_PASSWORD=CHANGE_ME_SET_SECURE_PASSWORD

# JWT Secret (mínimo 32 caracteres)
# Gere com: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_64

# Ambiente
ENVIRONMENT=production

# Configurações opcionais
COMPOSE_PROJECT_NAME=batuara
